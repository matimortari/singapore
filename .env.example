# Node environment (development, staging, production)
NODE_ENV="development"

# Public base URL of the application
NUXT_PUBLIC_BASE_URL="http://localhost:3000"

# PostgreSQL connection string (format: postgresql://username:password@host:port/database)
DATABASE_URL="postgresql://username:password@host:port/database"

# Docker socket path for communicating with the Docker daemon
NUXT_DOCKER_SOCKET_PATH=""

# Session encryption password. Generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=""

# Google OAuth client credentials. Get credentials from: https://console.cloud.google.com/apis/credentials
NUXT_OAUTH_GOOGLE_CLIENT_ID=""
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=""

# GitHub OAuth client credentials. Get credentials from: https://github.com/settings/developers
NUXT_OAUTH_GITHUB_CLIENT_ID=""
NUXT_OAUTH_GITHUB_CLIENT_SECRET=""
